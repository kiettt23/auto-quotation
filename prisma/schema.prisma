generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum PricingType {
  FIXED
  TIERED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

// ─── Settings (singleton) ───────────────────────────────

model Settings {
  id        String @id @default("default")
  // Company info
  companyName String   @default("") @map("company_name")
  address     String   @default("")
  phone       String   @default("")
  email       String   @default("")
  taxCode     String   @default("") @map("tax_code")
  website     String   @default("")
  // Bank info
  bankName    String   @default("") @map("bank_name")
  bankAccount String   @default("") @map("bank_account")
  bankOwner   String   @default("") @map("bank_owner")
  // Branding
  logoUrl      String @default("") @map("logo_url")
  primaryColor String @default("#0369A1") @map("primary_color")
  greetingText String @default("Kính gửi Quý khách hàng,\nCảm ơn Quý khách đã quan tâm đến sản phẩm/dịch vụ của chúng tôi. Chúng tôi xin gửi báo giá như sau:") @map("greeting_text")
  defaultTerms String @default("- Thời gian giao hàng: 3-5 ngày làm việc\n- Bảo hành: Theo chính sách nhà sản xuất\n- Thanh toán: Chuyển khoản 100% trước khi giao hàng\n- Báo giá có hiệu lực trong 30 ngày") @map("default_terms")
  // Display options
  showAmountInWords   Boolean @default(true) @map("show_amount_in_words")
  showBankInfo        Boolean @default(true) @map("show_bank_info")
  showSignatureBlocks Boolean @default(true) @map("show_signature_blocks")
  showFooterNote      Boolean @default(false) @map("show_footer_note")
  footerNote          String  @default("") @map("footer_note")
  // Quote defaults
  quotePrefix       String  @default("BG-{YYYY}-") @map("quote_prefix")
  quoteNextNumber   Int     @default(1) @map("quote_next_number")
  defaultVatPercent Decimal @default(10) @map("default_vat_percent") @db.Decimal(5, 2)
  defaultValidityDays Int   @default(30) @map("default_validity_days")
  defaultShipping   Decimal @default(0) @map("default_shipping") @db.Decimal(15, 0)
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ─── Category ───────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("categories")
}

// ─── Unit ───────────────────────────────────────────────

model Unit {
  id        String    @id @default(cuid())
  name      String
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("units")
}

// ─── Product ────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String      @default("")
  notes       String      @default("")
  categoryId  String      @map("category_id")
  category    Category    @relation(fields: [categoryId], references: [id])
  unitId      String      @map("unit_id")
  unit        Unit        @relation(fields: [unitId], references: [id])
  basePrice   Decimal     @default(0) @map("base_price") @db.Decimal(15, 0)
  pricingType PricingType @default(FIXED) @map("pricing_type")
  pricingTiers    PricingTier[]
  volumeDiscounts VolumeDiscount[]
  quoteItems      QuoteItem[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([code])
  @@map("products")
}

// ─── PricingTier ────────────────────────────────────────

model PricingTier {
  id          String  @id @default(cuid())
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity Int     @map("min_quantity")
  maxQuantity Int?    @map("max_quantity")
  price       Decimal @db.Decimal(15, 0)

  @@index([productId])
  @@map("pricing_tiers")
}

// ─── VolumeDiscount ─────────────────────────────────────

model VolumeDiscount {
  id              String  @id @default(cuid())
  productId       String  @map("product_id")
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity     Int     @map("min_quantity")
  discountPercent Decimal @map("discount_percent") @db.Decimal(5, 2)

  @@index([productId])
  @@map("volume_discounts")
}

// ─── Customer ───────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  company   String   @default("")
  phone     String   @default("")
  email     String   @default("")
  address   String   @default("")
  notes     String   @default("")
  quotes    Quote[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customers")
}

// ─── Quote ──────────────────────────────────────────────

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique @map("quote_number")
  customerId  String?     @map("customer_id")
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // Denormalized customer snapshot
  customerName    String @default("") @map("customer_name")
  customerCompany String @default("") @map("customer_company")
  customerPhone   String @default("") @map("customer_phone")
  customerEmail   String @default("") @map("customer_email")
  customerAddress String @default("") @map("customer_address")
  // Status & validity
  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?   @map("valid_until")
  // Pricing
  globalDiscountPercent Decimal @default(0) @map("global_discount_percent") @db.Decimal(5, 2)
  vatPercent            Decimal @default(10) @map("vat_percent") @db.Decimal(5, 2)
  shippingFee           Decimal @default(0) @map("shipping_fee") @db.Decimal(15, 0)
  otherFees             Decimal @default(0) @map("other_fees") @db.Decimal(15, 0)
  otherFeesLabel        String  @default("") @map("other_fees_label")
  // Notes
  notes String @default("")
  terms String @default("")
  // Share
  shareToken String? @unique @map("share_token")
  // Computed totals (stored for fast reads)
  subtotal       Decimal @default(0) @db.Decimal(15, 0)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(15, 0)
  vatAmount      Decimal @default(0) @map("vat_amount") @db.Decimal(15, 0)
  total          Decimal @default(0) @db.Decimal(15, 0)
  // Relations
  items QuoteItem[]
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([quoteNumber])
  @@index([shareToken])
  @@index([status])
  @@map("quotes")
}

// ─── DocTemplate (Excel/PDF template engine) ────────────

model DocTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String   @default("")
  // File type: "excel" or "pdf"
  fileType      String   @default("excel") @map("file_type")
  // Original file stored as base64
  fileBase64    String   @map("file_base64") @db.Text
  // Excel: sheet name to use; PDF: unused
  sheetName     String   @default("") @map("sheet_name")
  // Excel: [{ cellRef, label, type }]; PDF: [{ id, label, x, y, width, height, fontSize, type }]
  placeholders  Json     @default("[]")
  // Excel only: repeating row region { startRow, columns }
  tableRegion   Json?    @map("table_region")
  // Numbering
  docPrefix     String   @default("DOC-{YYYY}-") @map("doc_prefix")
  docNextNumber Int      @default(1) @map("doc_next_number")
  // Relations
  entries       DocEntry[]
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("doc_templates")
}

// ─── DocEntry (documents created from templates) ────────

model DocEntry {
  id         String      @id @default(cuid())
  templateId String      @map("template_id")
  template   DocTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  docNumber  String      @unique @map("doc_number")
  // Data: { placeholderCellRef: value, ... }
  fieldData  Json        @default("{}") @map("field_data")
  // Table rows: [{ colLetter: value, ... }]
  tableRows  Json        @default("[]") @map("table_rows")
  // Timestamps
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([templateId])
  @@index([docNumber])
  @@map("doc_entries")
}

// ─── QuoteItem ──────────────────────────────────────────

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String   @map("quote_id")
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sortOrder   Int      @default(0) @map("sort_order")
  // Item details (denormalized from product or custom)
  name        String
  description String   @default("")
  unit        String   @default("")
  // Pricing
  quantity        Int     @default(1)
  unitPrice       Decimal @default(0) @map("unit_price") @db.Decimal(15, 0)
  discountPercent Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  lineTotal       Decimal @default(0) @map("line_total") @db.Decimal(15, 0)
  // Custom item flag
  isCustomItem Boolean @default(false) @map("is_custom_item")

  @@index([quoteId])
  @@index([productId])
  @@map("quote_items")
}
